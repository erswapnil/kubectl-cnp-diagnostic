#!/bin/bash

# --- EDB/Postgres Cluster Diagnostic Collector (Master Version) ---

read -p "Enter the Namespace of the Cluster: " NAMESPACE
read -p "Enter the Cluster Name: " CLUSTER_NAME

echo "Select Operator Variant:"
echo "1) CNP (Cloud Native Postgres - EDB)"
echo "2) CNPG (CloudNativePG - Community)"
read -p "Enter choice [1 or 2]: " VARIANT_CHOICE

OP_CMD=$([ "$VARIANT_CHOICE" == "1" ] && echo "cnp" || echo "cnpg")

# 1. Directory Setup
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
MAIN_DIR="edb_diag_${CLUSTER_NAME}_${TIMESTAMP}"
mkdir -p "$MAIN_DIR/cluster_info" "$MAIN_DIR/operator_info/logs" "$MAIN_DIR/pods" "$MAIN_DIR/storage"

echo "Starting comprehensive collection..."

# 2. Operator Discovery & Versioning
OP_POD_INFO=$(kubectl get pods -A -l app.kubernetes.io/name=cloud-native-postgresql --no-headers | head -n 1)
OP_NS=$(echo "$OP_POD_INFO" | awk '{print $1}')
OP_POD_NAME=$(echo "$OP_POD_INFO" | awk '{print $2}')

if [ ! -z "$OP_POD_NAME" ]; then
    kubectl get pod "$OP_POD_NAME" -n "$OP_NS" -o jsonpath='{.spec.containers[0].image}' > "$MAIN_DIR/operator_info/operator_version.txt"
    kubectl get deployment -n "$OP_NS" -l app.kubernetes.io/name=cloud-native-postgresql -o yaml > "$MAIN_DIR/operator_info/operator_manifest.yaml"
    kubectl logs "$OP_POD_NAME" -n "$OP_NS" > "$MAIN_DIR/operator_info/logs/operator.log"
fi

# Barman Plugin Version
BARMAN_POD_INFO=$(kubectl get pods -A --no-headers | grep "barman-cloud" | head -n 1)
if [ ! -z "$BARMAN_POD_INFO" ]; then
    B_NS=$(echo $BARMAN_POD_INFO | awk '{print $1}')
    B_NAME=$(echo $BARMAN_POD_INFO | awk '{print $2}')
    kubectl get pod "$B_NAME" -n "$B_NS" -o jsonpath='{.spec.containers[0].image}' > "$MAIN_DIR/operator_info/barman_plugin_version.txt"
fi

# 3. Cluster Level Diagnostics
kubectl get cluster "$CLUSTER_NAME" -n "$NAMESPACE" -o yaml > "$MAIN_DIR/cluster_info/cluster_definition.yaml"
kubectl "$OP_CMD" status "$CLUSTER_NAME" -n "$NAMESPACE" > "$MAIN_DIR/cluster_info/cluster_status.txt"
kubectl get backup -n "$NAMESPACE" > "$MAIN_DIR/cluster_info/available_backups.txt"
kubectl get events -n "$NAMESPACE" --sort-by='.lastTimestamp' > "$MAIN_DIR/cluster_info/namespace_events.txt"
kubectl get pvc -n "$NAMESPACE" > "$MAIN_DIR/storage/pvc_list.txt"
kubectl get pv > "$MAIN_DIR/storage/all_pv_list.txt"

# 4. Pod & Multi-Database Diagnostics
PODS=$(kubectl get pods -n "$NAMESPACE" -l "cnpg.io/cluster=$CLUSTER_NAME" -o jsonpath='{.items[*].metadata.name}')
[ -z "$PODS" ] && PODS=$(kubectl get pods -n "$NAMESPACE" --no-headers -o custom-columns=":metadata.name" | grep "^${CLUSTER_NAME}-")

for POD in $PODS; do
    echo "--- Processing Pod: $POD ---"
    POD_DIR="$MAIN_DIR/pods/$POD"
    mkdir -p "$POD_DIR/postgresql"

    # Pod-level SQL diagnostics
    run_pod_sql() {
        kubectl exec -n "$NAMESPACE" "$POD" -c postgres -- psql -U postgres -c "$1" > "$POD_DIR/postgresql/$2" 2>/dev/null
    }

    run_pod_sql "SELECT version();" "db_version.out"
    run_pod_sql "SHOW ALL;" "show_all.out"
    run_pod_sql "SELECT * FROM pg_stat_replication;" "replication.out"
    run_pod_sql "SELECT * FROM pg_replication_slots;" "replication_slots.out"
    run_pod_sql "SELECT * FROM pg_stat_bgwriter;" "bgwriter.out"
    run_pod_sql "SELECT * FROM pg_stat_archiver;" "archiver.out"
    
    # Activity summary
    QUERY_ACT="SELECT COALESCE(state, 'internal/background') AS state, count(*) FROM pg_stat_activity GROUP BY 1 UNION ALL SELECT 'Total', count(*) FROM pg_stat_activity ORDER BY (state = 'Total') ASC, count DESC;"
    run_pod_sql "$QUERY_ACT" "activity_counts.out"

    # Database-level deep dive
    DB_LIST=$(kubectl exec -n "$NAMESPACE" "$POD" -c postgres -- psql -U postgres -t -c "SELECT datname FROM pg_database WHERE datallowconn AND NOT datname LIKE 'template%';" | xargs)

    for DB in $DB_LIST; do
        echo "   -> Collecting from Database: $DB"
        DB_SUBDIR="$POD_DIR/postgresql/db_$DB"
        mkdir -p "$DB_SUBDIR"

        run_db_sql() {
            kubectl exec -n "$NAMESPACE" "$POD" -c postgres -- psql -U postgres -d "$DB" -c "$1" > "$DB_SUBDIR/$2" 2>/dev/null
        }

        run_db_sql "SELECT * FROM pg_available_extensions WHERE installed_version IS NOT NULL;" "extensions.out"
        run_db_sql "SELECT * FROM pg_stat_user_tables;" "pg_stat_user_tables.out"
        run_db_sql "SELECT relname, n_live_tup, n_dead_tup FROM pg_stat_user_tables ORDER BY 3 DESC;" "table_tuples.out"
        run_db_sql "SELECT schemaname, relname, pg_size_pretty(pg_relation_size(relid)) as actual_size, n_dead_tup, last_autovacuum FROM pg_stat_all_tables ORDER BY n_dead_tup DESC;" "database_bloat.out"
        run_db_sql "SELECT schemaname, relname, indexrelname, pg_size_pretty(pg_relation_size(indexrelid)) AS index_size, idx_scan FROM pg_stat_user_indexes ORDER BY pg_relation_size(indexrelid) DESC;" "index_bloat.out"
        run_db_sql "SELECT * FROM pg_locks;" "pg_locks.out"
        run_db_sql "SELECT * FROM pg_stat_activity;" "pg_stat_activity.out"

        # Blocking logic
        BLOCK_Q1="SELECT blocked_locks.pid AS blocked_pid, blocked_activity.usename AS blocked_user, now() - blocked_activity.query_start AS blocked_duration, blocking_locks.pid AS blocking_pid, blocking_activity.usename AS blocking_user, now() - blocking_activity.query_start AS blocking_duration, blocked_activity.query AS blocked_statement, blocking_activity.query AS blocking_statement FROM pg_catalog.pg_locks AS blocked_locks JOIN pg_catalog.pg_stat_activity AS blocked_activity ON blocked_activity.pid = blocked_locks.pid JOIN pg_catalog.pg_locks AS blocking_locks ON blocking_locks.locktype = blocked_locks.locktype AND blocking_locks.DATABASE IS NOT DISTINCT FROM blocked_locks.DATABASE AND blocking_locks.relation IS NOT DISTINCT FROM blocked_locks.relation AND blocking_locks.page IS NOT DISTINCT FROM blocked_locks.page AND blocking_locks.tuple IS NOT DISTINCT FROM blocked_locks.tuple AND blocking_locks.virtualxid IS NOT DISTINCT FROM blocked_locks.virtualxid AND blocking_locks.transactionid IS NOT DISTINCT FROM blocked_locks.transactionid AND blocking_locks.classid IS NOT DISTINCT FROM blocked_locks.classid AND blocking_locks.objid IS NOT DISTINCT FROM blocked_locks.objid AND blocking_locks.objsubid IS NOT DISTINCT FROM blocked_locks.objsubid AND blocking_locks.pid != blocked_locks.pid JOIN pg_catalog.pg_stat_activity AS blocking_activity ON blocking_activity.pid = blocking_locks.pid WHERE NOT blocked_locks.granted;"
        run_db_sql "$BLOCK_Q1" "blocking_analysis_detailed.out"
        
        BLOCK_Q2="SELECT activity.pid, activity.usename, activity.query, blocking.pid AS blocking_id, blocking.query AS blocking_query FROM pg_stat_activity AS activity JOIN pg_stat_activity AS blocking ON blocking.pid = ANY(pg_blocking_pids(activity.pid));"
        run_db_sql "$BLOCK_Q2" "blocking_summary.out"
    done

    kubectl describe pod "$POD" -n "$NAMESPACE" > "$POD_DIR/describe_result.txt"
    kubectl logs "$POD" -n "$NAMESPACE" -c postgres > "$POD_DIR/postgresql/postgres.log"
done

# 5. Packaging and Cleanup
echo "--------------------------------------------------------"
tar -czf "${MAIN_DIR}.tar.gz" "$MAIN_DIR"
rm -rf "$MAIN_DIR"
echo "Collection complete: ${MAIN_DIR}.tar.gz"
